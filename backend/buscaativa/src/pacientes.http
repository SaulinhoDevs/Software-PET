### 09.01 — Criar agendamento passado para teste de frequência
# Objetivo: cadastrar agendamento válido.
# Esperado: 201; situação definida pelo service como AGENDADO; capturar id/version.
# Requisitos: RF05, RF06.
# @name criarAgendamentoPassado
POST {{baseUrl}}/api/agendamentos
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "id": null,
  "usuarioId": "{{profissionalIdPublico}}",
  "nomeProfissional": null,
  "pacienteId": "{{pacienteRiscoIdPublico}}",
  "nomePaciente": null,
  "tipoAcompanhamento": null,
  "dataAgendamento": "{{ontem}}",
  "turnoAgendamento": "MANHA",
  "horaAtendimento": "08:00:00",
  "situacaoAtendimento": 1,
  "agendamentoOriginalId": null,
  "version": null
}



### 09.02 — Criar agendamento como PROFISSIONAL
# Objetivo: confirmar matriz de autorização.
# Esperado: 403.
# Requisitos: RF05, RNF06.
POST {{baseUrl}}/api/agendamentos
Authorization: Bearer {{profissionalToken}}
Content-Type: application/json

{
  "usuarioId": "{{profissionalIdPublico}}",
  "pacienteId": "{{pacienteRiscoIdPublico}}",
  "dataAgendamento": "{{amanha}}",
  "turnoAgendamento": "MANHA",
  "horaAtendimento": "09:00:00"
}

### 09.03 — Criar agendamento como RECEPCAO
# Objetivo: validar perfil permitido.
# Esperado: 201.
# Requisitos: RF05, RNF06.
POST {{baseUrl}}/api/agendamentos
Authorization: Bearer {{recepcaoToken}}
Content-Type: application/json

{
  "usuarioId": "{{profissionalIdPublico}}",
  "pacienteId": "{{pacienteIdPublico}}",
  "dataAgendamento": "{{amanha}}",
  "turnoAgendamento": "MANHA",
  "horaAtendimento": "09:00:00"
}

# POSSÍVEL BUG RF04/RF05:
# AgendamentoServiceImpl.save não consulta disponibilidade, bloqueios, capacidade ou conflito de horário.
# Assim, a criação pode retornar 201 mesmo com data bloqueada, sem disponibilidade ou turno lotado.
# O endpoint /vagas calcula corretamente, mas não é usado para impedir o POST.

### 09.04 — Consultar agenda como ADMIN sem profissionalId
# Objetivo: listar todos os agendamentos da data.
# Esperado: 200.
# Requisitos: RF05.
GET {{baseUrl}}/api/agendamentos/agenda/{{ontem}}
Authorization: Bearer {{adminToken}}

### 09.05 — Registrar primeira FALTA
# Objetivo: atualizar status de atendimento passado.
# Esperado: 200; situacaoAtendimento=FALTOU; version incrementada.
# Requisitos: RF06, RF09.
# @name marcarFalta1
PATCH {{baseUrl}}/api/agendamentos/{{agendamentoId}}/status?novoStatus=FALTOU&version={{agendamentoVersion}}
Authorization: Bearer {{profissionalToken}}

> {%
client.global.set("agendamentoVersionAposFalta", response.body.version);
%}

### 09.06 — Repetir FALTOU com versão atual
# Objetivo: confirmar idempotência lógica; contador não deve incrementar novamente.
# Esperado: 200; service retorna sem alteração quando statusAnterior == novoStatus.
# Requisitos: RF06, RF09.
PATCH {{baseUrl}}/api/agendamentos/{{agendamentoId}}/status?novoStatus=FALTOU&version={{marcarFalta1.response.body.$.version}}
Authorization: Bearer {{profissionalToken}}

### 09.07 — Criar segundo agendamento passado
# Objetivo: preparar segunda falta consecutiva.
# Esperado: 201.
# @name criarAgendamentoFalta2
POST {{baseUrl}}/api/agendamentos
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "usuarioId": "{{profissionalIdPublico}}",
  "pacienteId": "{{pacienteRiscoIdPublico}}",
  "dataAgendamento": "{{ontem}}",
  "turnoAgendamento": "MANHA",
  "horaAtendimento": "08:30:00"
}

### 09.08 — Registrar segunda FALTA
# Objetivo: countFaltas=2 e risco interno AMARELO.
# Esperado: 200.
# @name marcarFalta2
PATCH {{baseUrl}}/api/agendamentos/{{agendamentoFalta2Id}}/status?novoStatus=FALTOU&version={{criarAgendamentoFalta2.response.body.$.version}}
Authorization: Bearer {{profissionalToken}}

### 09.09 — Criar terceiro agendamento passado
# Objetivo: preparar risco vermelho.
# Esperado: 201.
# @name criarAgendamentoFalta3
POST {{baseUrl}}/api/agendamentos
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "usuarioId": "{{profissionalIdPublico}}",
  "pacienteId": "{{pacienteRiscoIdPublico}}",
  "dataAgendamento": "{{ontem}}",
  "turnoAgendamento": "MANHA",
  "horaAtendimento": "09:00:00"
}

### 09.10 — Registrar terceira FALTA
# Objetivo: countFaltas=3 e risco VERMELHO.
# Esperado: 200; depois execute 07.05.
# @name marcarFalta3
PATCH {{baseUrl}}/api/agendamentos/{{agendamentoFalta3Id}}/status?novoStatus=FALTOU&version={{criarAgendamentoFalta3.response.body.$.version}}
Authorization: Bearer {{profissionalToken}}

### 09.11 — Alterar FALTOU para PRESENTE
# Objetivo: zerar faltas e atualizar última presença.
# Esperado: 200; depois execute 07.06 e 07.07.
# Requisitos: RF06, RF09.
PATCH {{baseUrl}}/api/agendamentos/{{agendamentoId}}/status?novoStatus=PRESENTE&version={{marcarFalta1.response.body.$.version}}
Authorization: Bearer {{profissionalToken}}

### 09.12 — Tentar registrar frequência em data futura
# Objetivo: validar bloqueio temporal.
# Esperado: 400; mensagem "Não é permitido registrar presença ou falta...".
# Pré-requisito: execute 09.03 e copie o id retornado, caso não use um request nomeado.
# Requisitos: RF06.
# Substitua ID_AGENDAMENTO_FUTURO pelo id retornado em 09.03.
PATCH {{baseUrl}}/api/agendamentos/ID_AGENDAMENTO_FUTURO/status?novoStatus=PRESENTE
Authorization: Bearer {{profissionalToken}}

### 09.13 — Conflito otimista com versão antiga
# Objetivo:
# 1) versão original veio de criarAgendamentoPassado;
# 2) marcarFalta1 atualizou;
# 3) esta chamada reutiliza a versão original.
# Esperado: 409 Conflict.
# Requisitos: RF06, RNF09.
PATCH {{baseUrl}}/api/agendamentos/{{agendamentoId}}/status?novoStatus=CANCELADO&version={{criarAgendamentoPassado.response.body.$.version}}
Authorization: Bearer {{adminToken}}

### 09.14 — Atualizar status como RECEPCAO
# Objetivo: confirmar permissão real.
# Esperado no código: 200.
# Avaliar se RECEPCAO deveria registrar presença/falta segundo RNF06.
PATCH {{baseUrl}}/api/agendamentos/{{agendamentoFalta2Id}}/status?novoStatus=PRESENTE&version={{marcarFalta2.response.body.$.version}}
Authorization: Bearer {{recepcaoToken}}

