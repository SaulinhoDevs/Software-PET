# Esperado: 200.
# Requisitos: RF05.
GET {{baseUrl}}/api/agendamentos/agenda/{{ontem}}?profissionalId={{profissionalIdPublico}}
Authorization: Bearer {{adminToken}}

### 09.17 — Consultar agenda como RECEPCAO sem profissionalId
# Objetivo: listar toda a agenda da data.
# Esperado: 200.
# Requisitos: RF05.
GET {{baseUrl}}/api/agendamentos/agenda/{{ontem}}
Authorization: Bearer {{recepcaoToken}}

# CONTRATO DA AGENDA
# AgendamentoDTO retorna:
# id, usuarioId, nomeProfissional, pacienteId, nomePaciente, tipoAcompanhamento,
# dataAgendamento, turnoAgendamento, horaAtendimento, situacaoAtendimento,
# agendamentoOriginalId e version.
# Isso cobre paciente, profissional, data/hora, acompanhamento e situação, desde que o Mapper preencha os nomes.

### 09.18 — Criar consulta original para remarcação
# Objetivo: preparar RF08.
# Esperado: 201.
# @name criarOriginalRemarcacao
POST {{baseUrl}}/api/agendamentos
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "usuarioId": "{{profissionalIdPublico}}",
  "pacienteId": "{{pacienteRuaIdPublico}}",
  "dataAgendamento": "{{ontem}}",
  "turnoAgendamento": "TARDE",
  "horaAtendimento": "14:00:00"
}

### 09.19 — Registrar falta na consulta original
# Objetivo: primeira falta antes da remarcação.
# Esperado: 200.
PATCH {{baseUrl}}/api/agendamentos/{{agendamentoOriginalRemarcacaoId}}/status?novoStatus=FALTOU&version={{criarOriginalRemarcacao.response.body.$.version}}
Authorization: Bearer {{profissionalToken}}

### 09.20 — Pedir três sugestões de remarcação
# Objetivo: testar datas disponíveis.
# Esperado: 200 com até três datas futuras.
# Requisitos: RF05/RF08.
GET {{baseUrl}}/api/agendamentos/{{agendamentoOriginalRemarcacaoId}}/remarcacao
Authorization: Bearer {{recepcaoToken}}

### 09.21 — Criar remarcação vinculada
# Objetivo: criar novo agendamento ligado ao original.
# IMPORTANTE: embora AgendamentoDTO tenha agendamentoOriginalId, o service usa o campo id para localizar
# o original. Por isso, este teste envia id = agendamento original.
# Esperado: 201; original muda para REMARCADO_ORIGEM e novo fica REMARCADO.
# POSSÍVEL BUG/GAP de contrato: agendamentoOriginalId é ignorado no save.
# @name criarRemarcacao
POST {{baseUrl}}/api/agendamentos
Authorization: Bearer {{recepcaoToken}}
Content-Type: application/json

{
  "id": {{agendamentoOriginalRemarcacaoId}},
  "usuarioId": "{{profissionalIdPublico}}",
  "pacienteId": "{{pacienteRuaIdPublico}}",
  "dataAgendamento": "{{ontem}}",
  "turnoAgendamento": "TARDE",
  "horaAtendimento": "15:00:00",
  "agendamentoOriginalId": {{agendamentoOriginalRemarcacaoId}}
}

> {%
if (response.body && response.body.id) {
  client.global.set("agendamentoRemarcadoId", response.body.id);
}
%}

### 09.22 — Registrar falta na consulta remarcada
# Objetivo: acionar gatilho de visita/busca em ponto de referência.
# Esperado: 200. Depois, acumule faltas até VERMELHO e consulte /busca-ativa.
# Requisitos: RF08.
PATCH {{baseUrl}}/api/agendamentos/{{agendamentoRemarcadoId}}/status?novoStatus=FALTOU&version={{criarRemarcacao.response.body.$.version}}
Authorization: Bearer {{profissionalToken}}

### 09.23 — Consultar busca ativa após falta em remarcação
# Objetivo: verificar alerta:
# - situacaoRua=false: "Visita domiciliar necessária" + endereço;
# - situacaoRua=true: "Busca em ponto de referência necessária" + complemento;
# - rua sem complemento: avisoAdicional.
# ATENÇÃO: o endpoint só lista ATIVOS e VERMELHOS. O gatilho sozinho não basta para aparecer.
# Requisitos: RF08, RF10, RF02.
GET {{baseUrl}}/api/pacientes/busca-ativa
Authorization: Bearer {{adminToken}}

### 09.24 — Lotar turno e consultar vagas
# Objetivo: criar agendamentos até a capacidade e consultar /vagas.
# Execute POSTs adicionais como 09.03 para @amanha/MANHA e então execute:
GET {{baseUrl}}/api/agendamentos/vagas?usuarioId={{profissionalIdPublico}}&data={{amanha}}
Authorization: Bearer {{adminToken}}

# NÃO TESTÁVEL VIA REST CLIENT — parte frontend do RF05:
# funcionamento offline, IndexedDB, service worker e sincronização no navegador.
# Exige inspeção e testes do frontend, DevTools/Application/Network e cenário offline real.


# =================================================================================================
# 10 — MATRIZ DE REQUISITOS, GAPS E RESULTADO FINAL
# =================================================================================================

# REQUISITOS FUNCIONAIS
# RF01 — TESTÁVEL: logins, token, sem token, token inválido e três perfis.
# RF02 — PARCIAL: busca ativa existe, mas contrato não devolve CNS, acompanhamento e última presença.
# RF03 — TESTÁVEL: CPF, CNS, nome completo/parcial; GAP mínimo de três caracteres.
# RF04 — PARCIAL: CRUD básico/vagas/bloqueio; POST de agendamento não aplica capacidade/bloqueio.
# RF05 — PARCIAL: agenda REST testável; offline/IndexedDB/service worker não testável via REST Client.
# RF06 — TESTÁVEL: presença, falta, data futura, idempotência e versão otimista.
# RF08 — PARCIAL: remarcação/gatilho; auditoria de visualização/encaminhamento sem endpoint.
# RF09 — TESTÁVEL: faltas e presença; cor amarela não exposta no PacienteDTO.
# RF10 — PARCIAL: vermelho testável pela busca ativa; amarelo não exposto; AMBOS usa limites de individual.
# RF13 — NÃO IMPLEMENTADO: limites fixos; sem endpoint de configuração.
# RF14 — TESTÁVEL: mensagens em 422/400/409; avaliar clareza da resposta real.
# RF15 — PARCIAL/FALHA: duplicidade por documentos existe; similaridade sem documentos é bloqueada por @NotBlank.
# RF16 — TESTÁVEL/PARCIAL: encerrar e reativar; sem endpoint de auditoria; possível bypass com status ATIVO.
# RF22 — PARCIAL: CRUD existe, mas escrita/inativação só para ADMIN.
# RF23 — TESTÁVEL: CRUD de usuários; respostas usam senha null.
# RF24 — NÃO IMPLEMENTADO: nenhum endpoint de histórico do paciente encontrado.

# MATRIZ DE RNFs
# RNF01 | NÃO TESTÁVEL VIA REST CLIENT       | Interface simples exige avaliação de UI/usabilidade.
# RNF04 | PARCIALMENTE TESTADO               | API web responde HTTP; frontend completo não é validado.
# RNF05 | TESTADO VIA REST CLIENT            | JWT, rotas protegidas e cenários negativos; logs exigem inspeção manual.
# RNF06 | TESTADO VIA REST CLIENT            | Matriz por perfil; foram identificados gaps de propriedade/permissão.
# RNF07 | PARCIALMENTE TESTADO               | Respostas sem senha; FALHA: senha/token aparecem em logs.
# RNF08 | NÃO IMPLEMENTADO/SEM EVIDÊNCIA     | Sem endpoints específicos de consentimento, base legal, retenção ou direitos LGPD.
# RNF09 | PARCIALMENTE TESTADO               | @Version em agendamento; demais concorrências/integridade não cobertas.
# RNF11 | NÃO TESTÁVEL VIA REST CLIENT       | Organização do código exige revisão estática.
# RNF12 | NÃO TESTÁVEL VIA REST CLIENT       | Escalabilidade exige carga, métricas e arquitetura.
# RNF13 | NÃO TESTÁVEL VIA REST CLIENT       | Compatibilidade Chrome/Firefox/Edge exige testes de navegador.
# RNF14 | NÃO TESTÁVEL VIA REST CLIENT       | Java/Spring Boot verificados no código, não pela execução HTTP isolada.
# RNF15 | NÃO TESTÁVEL VIA REST CLIENT       | Custo/licenças exigem análise de dependências/infra.
# RNF16 | PARCIALMENTE TESTADO               | Erros, validações e idempotência; sem teste de resiliência/carga.
# RNF17 | PARCIALMENTE TESTADO               | Envers/campos existem; sem endpoint para consultar trilha de auditoria.
# RNF18 | NÃO IMPLEMENTADO/SEM EVIDÊNCIA     | README atual não documenta implantação do backend.
# RNF20 | NÃO TESTÁVEL VIA REST CLIENT       | Responsividade exige testes de frontend/dispositivos.

# -------------------------------------------------------------------------------------------------
# 1. TESTES PRONTOS PARA EXECUTAR
# -------------------------------------------------------------------------------------------------
# - Login e autenticação dos três perfis.
# - Matriz de acesso sem token, token inválido e perfis permitidos/proibidos.
# - CRUD e validações de usuário.
# - Listagem de unidades.
# - Cadastro, consulta, busca, edição, validações, duplicidades e inativação de paciente.
# - Disponibilidade, duplicidade, atualização, listagem, exclusão e teste de propriedade.
# - Bloqueio, vagas bloqueadas/desbloqueadas e listagem.
# - Agendamento, agenda, frequência, repetição de status, data futura e conflito de versão.
# - Faltas, risco vermelho, busca ativa, remarcação, gatilho de visita, encerramento e reativação.

# -------------------------------------------------------------------------------------------------
# 2. PRÉ-REQUISITOS/DADOS QUE PRECISAM SER PREENCHIDOS
# -------------------------------------------------------------------------------------------------
# - Backend rodando em {{baseUrl}} com perfil dev.
# - Executar loginAdmin/loginProfissional/loginRecepcao.
# - Executar meAdmin/meProfissional/meRecepcao.
# - Executar listarUnidades e garantir que exista response.body[0].id.
# - Ajustar @diaSemanaAgenda para o dia da semana de @amanha.
# - Em 09.12, substituir ID_AGENDAMENTO_FUTURO pelo id retornado no agendamento futuro.
# - Evitar repetir cadastros após reiniciar apenas parcialmente; o H2 em memória é zerado ao reiniciar.

# -------------------------------------------------------------------------------------------------
# 3. REQUISITOS NÃO IMPLEMENTADOS OU NÃO VERIFICÁVEIS
# -------------------------------------------------------------------------------------------------
# - RF24: sem endpoint de histórico.
# - RF13: sem configuração dos seis critérios; valores fixos no service.
# - Auditoria: sem endpoint de consulta de Envers/usuário/data/motivo.
# - Offline, IndexedDB, service worker, sincronização, responsividade e navegadores: frontend.
# - LGPD: sem endpoints/evidências suficientes para ciclo de dados e direitos do titular.
# - Criação/edição de USF: inexistente na API.
# - Classificação AMARELO: não exposta pelo PacienteDTO.
# - Busca ativa não expõe todos os campos exigidos no RF02.

# -------------------------------------------------------------------------------------------------
# 4. POSSÍVEIS BUGS ENCONTRADOS NO CÓDIGO
# -------------------------------------------------------------------------------------------------
# - AuthController imprime e-mail e SENHA em texto puro no console.
# - SecurityFilter imprime header Authorization e token.
# - Edição de paciente pode acusar o próprio CPF/CNS como duplicado: compara Long id com UUID idPublico.
# - Similaridade sem CPF/CNS é inalcançável por @NotBlank nos dois documentos.
# - Paciente em situação de rua continua obrigado a enviar Endereco.
# - Busca por nome não exige três caracteres; q vazio pode listar todos.
# - Encerramento não bloqueia statusPaciente=ATIVO explicitamente.
# - Profissional pode excluir disponibilidade/bloqueio de outro usuário se souber o ID numérico.
# - Delete de disponibilidade/bloqueio não verifica existência/dono no service.
# - Capacidade aceita zero/valor negativo por falta de @Positive.
# - POST de agendamento não verifica bloqueio, disponibilidade, capacidade nem colisão de horário.
# - Campo agendamentoOriginalId do DTO é ignorado; remarcação usa o campo id como original.
# - dataUltimaPresenca é gravada com a data atual, não com dataAgendamento.
# - AMBOS utiliza limites de ausência do acompanhamento INDIVIDUAL.
# - Ausência/token inválido pode resultar em 403 em vez de 401 por falta de AuthenticationEntryPoint explícito.
