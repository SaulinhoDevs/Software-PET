# =================================================================================================
# SIBRAPS-PET — SUÍTE MANUAL DE API PARA REST CLIENT (VS CODE)
# Arquivo-alvo: backend/buscaativa/src/pacientes.http
# Backend analisado: LizReis/SIBRAPS-PET — branch main
#
# COMO EXECUTAR
# 1) Inicie o backend em backend/buscaativa com o perfil dev.
# 2) Execute os três logins da seção 02.
# 3) Execute /me para capturar os UUIDs dos perfis.
# 4) Execute a listagem de unidades e confirme que existe pelo menos uma USF.
# 5) Execute as requisições na ordem indicada dentro de cada cenário.
#
# OBSERVAÇÃO SOBRE VARIÁVEIS DINÂMICAS
# O REST Client resolve os tokens e IDs pelas respostas nomeadas, por exemplo:
#   {{loginAdmin.response.body.$.token}}
# Os scripts > {% ... %} também salvam os valores como variáveis globais.
#
# OBSERVAÇÃO SOBRE DATAS
# As macros {{$localDatetime ...}} dependem de versão atual da extensão REST Client.
# Caso não funcionem, substitua manualmente hoje/ontem/amanhã por datas no formato AAAA-MM-DD.
# =================================================================================================

@baseUrl = http://localhost:8080

# Credenciais criadas automaticamente por DevConfig no perfil dev
@adminEmail = admin@pet.com
@adminSenha = 123456
@profissionalEmail = profissional@pet.com
@profissionalSenha = 123456
@recepcaoEmail = recepcao@pet.com
@recepcaoSenha = 123456

# Tokens: execute primeiro as requisições nomeadas loginAdmin, loginProfissional e loginRecepcao
@adminToken = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJidXNjYWF0aXZhLWFwaSIsInN1YiI6ImFkbWluQHBldC5jb20iLCJleHAiOjE3ODQ3NTUzNTF9.4pJwYBzfQydNzuxm7AdKxSCEuQ3QFGcxjOCV5wYXqMU
@profissionalToken = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJidXNjYWF0aXZhLWFwaSIsInN1YiI6InByb2Zpc3Npb25hbEBwZXQuY29tIiwiZXhwIjoxNzg0NzU1OTExfQ.6mzXJ7HxOU8o-Fkhh2V6-wIFDI0mkyWTm0C88JWka40
@recepcaoToken = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJidXNjYWF0aXZhLWFwaSIsInN1YiI6InJlY2VwY2FvQHBldC5jb20iLCJleHAiOjE3ODQ3NTU5NDB9.xFGOjibTgVC1UThIyx6MD9dmJRz76CqsqC1r5skjRAM

# IDs públicos: execute /me de cada perfil ou a listagem de usuários
@adminIdPublico = {{meAdmin.response.body.$.idPublico}}
@profissionalIdPublico = 91b5777d-4380-4607-ba0c-a9722ad90c6a
@recepcaoIdPublico = {{meRecepcao.response.body.$.idPublico}}
@usuarioTesteIdPublico = a05220f1-0666-41a9-bef5-53b8f6a8de75
@profissional2IdPublico = 7318e9cc-b38e-4912-b6cd-7a9a307333fa

# Unidade: execute listarUnidades e confirme que response.body[0] é uma USF válida
@usfId = {{listarUnidades.response.body.$[0].id}}

# Pacientes
@pacienteIdPublico = cd42297f-d79e-47bb-bc64-b71e905323a3
@pacienteRuaIdPublico = de0e67d6-42ea-4970-93bc-6ec33dc18a34
@pacienteRiscoIdPublico = {{criarPacienteRisco.response.body.$.idPublico}}

# Disponibilidade e bloqueio
@disponibilidadeId = 1
@disponibilidadeProf2Id = 4
@bloqueioId = 1

# Agendamentos
@agendamentoId = {{criarAgendamentoPassado.response.body.$.id}}
@agendamentoVersion = {{criarAgendamentoPassado.response.body.$.version}}
@agendamentoFalta2Id = {{criarAgendamentoFalta2.response.body.$.id}}
@agendamentoFalta3Id = {{criarAgendamentoFalta3.response.body.$.id}}
@agendamentoOriginalRemarcacaoId = {{criarOriginalRemarcacao.response.body.$.id}}
@agendamentoRemarcadoId = {{criarRemarcacao.response.body.$.id}}

# Datas
@hoje = 2026-07-22
@ontem = 2026-07-21
@amanha = 2026-07-23

# Ajuste manualmente para corresponder ao dia da semana de @amanha.
# Exemplo em 22/07/2026: WEDNESDAY
@diaSemanaAgenda = WEDNESDAY

# Documentos válidos usados nesta suíte
@cpfPacienteFixo = 52998224725
@cnsPacienteFixo = 700000000000005
@cpfPacienteRua = 11144477735
@cnsPacienteRua = 800000000000001
@cpfPacienteRisco = 12345678909
@cnsPacienteRisco = 900000000000008


# =================================================================================================
# 00 — PRÉ-REQUISITOS E OBSERVAÇÕES
# =================================================================================================

# PERFIL DEV
# DevConfig cria três contas em cada inicialização do H2 em memória:
# - ADMINISTRADOR: admin@pet.com / 123456
# - PROFISSIONAL: profissional@pet.com / 123456
# - RECEPCAO: recepcao@pet.com / 123456
#
# O application.properties ativa o perfil dev e o banco H2 é em memória.
# Reiniciar o backend apaga a massa criada por esta suíte.
#
# UNIDADES DE SAÚDE
# Não existe endpoint POST para criar USF. O endpoint GET depende da tabela tb_usf_referencia,
# alimentada pelo serviço de sincronização. Se GET /api/unidades-saude retornar [], o cadastro
# válido de paciente ficará bloqueado. Preencha uma USF somente no ambiente de desenvolvimento.
#
# STATUS REAIS DE VALIDAÇÃO
# - Bean Validation (@Valid): 422 Unprocessable Entity, conforme ResourceExceptionHandler.
# - Regra de negócio/ValidationException/DatabaseException: 400.
# - Recurso duplicado: 409.
# - Não encontrado: 404 em ResourceNotFoundException; alguns fluxos usam DatabaseException e retornam 400.
# - Sem permissão: 403.
# - Sem token/token inválido: a configuração não define AuthenticationEntryPoint customizado e desativa
#   usuário anônimo; validar na execução. A tendência da configuração atual é 403, embora APIs REST
#   normalmente usem 401 para ausência/invalidade de autenticação.
#
# FALHA DE PRIVACIDADE ENCONTRADA
# AuthController imprime a senha do login no console.
# SecurityFilter imprime Authorization, token recebido e parte do token extraído.
# O REST Client não consegue provar ausência de senha/token nos logs: inspecione o terminal do backend.


# =================================================================================================
# 01 — INICIALIZAÇÃO E CRIAÇÃO DE USUÁRIOS
# =================================================================================================

### 01.01 — Criar usuário de teste como ADMINISTRADOR
# Objetivo: validar RF23 — cadastro com nome, e-mail, senha, perfil e unidade.
# Esperado: 201 Created; senha deve ser null/ausente na resposta.
# Requisitos: RF23, RNF05, RNF06, RNF07.
# @name criarUsuarioTeste
POST {{baseUrl}}/api/usuarios
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "idPublico": null,
  "nome": "TESTE REST RECEPCAO",
  "email": "teste.rest.recepcao@pet.com",
  "tipoUsuario": "RECEPCAO",
  "unidadeAtuacao": "USF",
  "senha": "123456"
}


### 01.02 — Criar segundo profissional para testes de isolamento/autorização
# Objetivo: preparar teste de alteração/exclusão de recurso pertencente a outro profissional.
# Esperado: 201 Created.
# Requisitos: RF23, RNF06.
# @name criarProfissional2
POST {{baseUrl}}/api/usuarios
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "idPublico": null,
  "nome": "TESTE REST PROFISSIONAL 2",
  "email": "teste.rest.profissional2@pet.com",
  "tipoUsuario": "PROFISSIONAL",
  "unidadeAtuacao": "CAPS_AD",
  "senha": "123456"
}


### 01.03 — Tentar criar usuário sem token
# Objetivo: confirmar proteção do endpoint de criação.
# Esperado pela configuração atual: 403. Convencionalmente, ausência de autenticação deveria ser 401.
# Requisitos: RF01, RF23, RNF05, RNF06.
POST {{baseUrl}}/api/usuarios
Content-Type: application/json

{
  "nome": "TESTE SEM TOKEN",
  "email": "sem.token@pet.com",
  "tipoUsuario": "RECEPCAO",
  "unidadeAtuacao": "USF",
  "senha": "123456"
}

### 01.04 — Tentar criar usuário como PROFISSIONAL
# Objetivo: validar matriz de autorização.
# Esperado: 403 Forbidden.
# Requisitos: RF23, RNF06.
POST {{baseUrl}}/api/usuarios
Authorization: Bearer {{profissionalToken}}
Content-Type: application/json

{
  "nome": "TESTE NAO AUTORIZADO",
  "email": "prof.nao.autorizado@pet.com",
  "tipoUsuario": "RECEPCAO",
  "unidadeAtuacao": "USF",
  "senha": "123456"
}

### 01.05 — Tentar criar usuário como RECEPCAO
# Objetivo: validar matriz de autorização.
# Esperado: 403 Forbidden.
# Requisitos: RF23, RNF06.
POST {{baseUrl}}/api/usuarios
Authorization: Bearer {{recepcaoToken}}
Content-Type: application/json

{
  "nome": "TESTE NAO AUTORIZADO",
  "email": "recepcao.nao.autorizada@pet.com",
  "tipoUsuario": "PROFISSIONAL",
  "unidadeAtuacao": "CAPS_II",
  "senha": "123456"
}

### 01.06 — E-mail duplicado
# Objetivo: validar rejeição de duplicidade.
# Esperado: 409 Conflict; mensagem "E-mail já cadastrado no sistema!".
# Requisitos: RF23, RF14.
POST {{baseUrl}}/api/usuarios
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "nome": "DUPLICADO",
  "email": "{{adminEmail}}",
  "tipoUsuario": "ADMINISTRADOR",
  "unidadeAtuacao": "USF",
  "senha": "123456"
}

### 01.07 — Usuário sem campos obrigatórios
# Objetivo: validar Bean Validation.
# Esperado: 422 Unprocessable Entity.
# Requisitos: RF23, RF14.
POST {{baseUrl}}/api/usuarios
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "nome": "",
  "email": "",
  "tipoUsuario": null,
  "unidadeAtuacao": null,
  "senha": ""
}

### 01.08 — Senha menor que seis caracteres
# Objetivo: validar @Size(min = 6).
# Esperado: 422 Unprocessable Entity.
# Requisitos: RF23, RF14.
POST {{baseUrl}}/api/usuarios
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "nome": "TESTE SENHA CURTA",
  "email": "senha.curta@pet.com",
  "tipoUsuario": "RECEPCAO",
  "unidadeAtuacao": "USF",
  "senha": "12345"
}


# =================================================================================================
# 02 — LOGIN/AUTENTICAÇÃO
# =================================================================================================

### 02.01 — Login ADMINISTRADOR válido
# Objetivo: confirmar retorno de token e tipo Bearer.
# Esperado: 200 OK; body.token preenchido; body.tipo = "Bearer".
# Requisitos: RF01, RNF05.
# @name loginAdmin
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "{{adminEmail}}",
  "senha": "{{adminSenha}}"
}


### 02.02 — Login PROFISSIONAL válido
# Objetivo: autenticar perfil PROFISSIONAL.
# Esperado: 200 OK com token Bearer.
# Requisitos: RF01, RNF05, RNF06.
# @name loginProfissional
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "{{profissionalEmail}}",
  "senha": "{{profissionalSenha}}"
}


### 02.03 — Login RECEPCAO válido
# Objetivo: autenticar perfil RECEPCAO.
# Esperado: 200 OK com token Bearer.
# Requisitos: RF01, RNF05, RNF06.
# @name loginRecepcao
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "{{recepcaoEmail}}",
  "senha": "{{recepcaoSenha}}"
}


### 02.04 — Login com senha inválida
# Objetivo: impedir autenticação com credencial incorreta.
# Resultado a conferir: 401 ou 403. Não há handler explícito de AuthenticationException no projeto.
# FALHA se retornar 200 ou 500.
# Requisitos: RF01, RNF05.
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "{{adminEmail}}",
  "senha": "senha-incorreta"
}

### 02.05 — Login com e-mail inexistente
# Objetivo: impedir autenticação de conta inexistente sem revelar detalhes sensíveis.
# Resultado a conferir: 401 ou 403. FALHA se 200 ou 500.
# Requisitos: RF01, RNF05, RNF07.
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "nao.existe@pet.com",
  "senha": "123456"
}

### 02.06 — Login sem body válido
# Objetivo: verificar robustez do endpoint, que não usa @Valid em LoginDTO.
# Resultado provável: 4xx; FALHA se 500.
# Requisitos: RF01, RNF16.
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{}


# =================================================================================================
# 03 — SEGURANÇA E CONTROLE DE ACESSO
# =================================================================================================

### 03.01 — Rota protegida sem token
# Objetivo: confirmar que qualquer rota fora das exceções exige autenticação.
# Esperado pela configuração atual: 403; registrar se 401.
# Requisitos: RF01, RNF05.
GET {{baseUrl}}/api/usuarios

### 03.02 — Rota protegida com token inválido
# Objetivo: rejeitar token adulterado.
# Esperado: 401 ou 403. FALHA se 200 ou 500.
# Requisitos: RF01, RNF05.
GET {{baseUrl}}/api/usuarios
Authorization: Bearer token-invalido

### 03.03 — Token ADMINISTRADOR em rota autenticada
# Objetivo: confirmar autenticação do ADMIN.
# Esperado: 200 OK.
# Requisitos: RF01, RNF06.
GET {{baseUrl}}/api/usuarios/me
Authorization: Bearer {{adminToken}}

### 03.04 — Token PROFISSIONAL em rota autenticada
# Objetivo: confirmar autenticação do PROFISSIONAL.
# Esperado: 200 OK.
# Requisitos: RF01, RNF06.
GET {{baseUrl}}/api/usuarios/me
Authorization: Bearer {{profissionalToken}}

### 03.05 — Token RECEPCAO em rota autenticada
# Objetivo: confirmar autenticação da RECEPCAO.
# Esperado: 200 OK.
# Requisitos: RF01, RNF06.
GET {{baseUrl}}/api/usuarios/me
Authorization: Bearer {{recepcaoToken}}

# MATRIZ DE AUTORIZAÇÃO OBSERVADA NO CÓDIGO
# Endpoint/ação                                      ADMIN   PROFISSIONAL   RECEPCAO   sem token
# GET usuários, usuário/{id}, /me                    200     200            200        401/403
# POST/PUT/DELETE usuários                           sim     403            403        401/403
# GET/listar/buscar pacientes                        200     200            200        401/403
# POST/PUT/DELETE(inativar) pacientes                sim     403            403        401/403
# GET busca ativa                                    200     200            200        401/403
# PATCH encerrar paciente                            sim     sim            403        401/403
# PATCH reativar paciente                            sim     403            403        401/403
# POST/DELETE disponibilidade e bloqueio             sim     sim            403        401/403
# GET disponibilidade e bloqueio                     sim     sim            sim        401/403
# POST agendamento                                   sim     403            sim        401/403
# GET agenda/vagas                                   sim     sim            sim        401/403
# PATCH status/frequência                            sim     sim            sim        401/403
#
# GAP RNF06: RF22 citado no roteiro pede editar/inativar por PROFISSIONAL/ADMIN/RECEPCAO,
# mas PacienteController restringe POST, PUT e DELETE exclusivamente a ADMINISTRADOR.
#
# FALHA RNF07: AuthController imprime senha; SecurityFilter imprime token/header Authorization.
# Inspeção: execute um login e observe o terminal do Spring Boot.


# =================================================================================================
# 04 — USUÁRIOS
# =================================================================================================

### 04.01 — Listar usuários como ADMIN
# Objetivo: listar usuários e capturar IDs dos dados iniciais.
# Esperado: 200; respostas não devem conter hash/senha.
# Requisitos: RF23, RNF07.
# @name listarUsuarios
GET {{baseUrl}}/api/usuarios
Authorization: Bearer {{adminToken}}

> {%
client.test("Nenhuma senha deve ser exposta", function () {
  const usuarios = Array.isArray(response.body) ? response.body : [];
  usuarios.forEach(function (u) {
    client.assert(u.senha === null || u.senha === undefined,
      "FALHA RNF07: senha devolvida para " + u.email);
  });
});
(response.body || []).forEach(function (u) {
  if (u.email === "admin@pet.com") client.global.set("adminIdPublico", u.idPublico);
  if (u.email === "profissional@pet.com") client.global.set("profissionalIdPublico", u.idPublico);
  if (u.email === "recepcao@pet.com") client.global.set("recepcaoIdPublico", u.idPublico);
});
%}

### 04.02 — Consultar /me como ADMIN
# Objetivo: retornar apenas os dados do usuário autenticado.
# Esperado: 200 e e-mail admin@pet.com; senha null.
# Requisitos: RF23, RNF05, RNF07.
# @name meAdmin
GET {{baseUrl}}/api/usuarios/me
Authorization: Bearer {{adminToken}}

> {%
client.assert(response.body.email === "admin@pet.com", "Usuário de /me incorreto.");
client.assert(response.body.senha === null || response.body.senha === undefined, "Senha exposta.");
client.global.set("adminIdPublico", response.body.idPublico);
%}

### 04.03 — Consultar /me como PROFISSIONAL
# Objetivo: capturar UUID público do profissional.
# Esperado: 200 e e-mail profissional@pet.com.
# Requisitos: RF23.
# @name meProfissional
GET {{baseUrl}}/api/usuarios/me
Authorization: Bearer {{profissionalToken}}

> {%
client.global.set("profissionalIdPublico", response.body.idPublico);
%}

### 04.04 — Consultar /me como RECEPCAO
# Objetivo: capturar UUID público da recepção.
# Esperado: 200 e e-mail recepcao@pet.com.
# Requisitos: RF23.
# @name meRecepcao
GET {{baseUrl}}/api/usuarios/me
Authorization: Bearer {{recepcaoToken}}

> {%
client.global.set("recepcaoIdPublico", response.body.idPublico);
%}

### 04.05 — Buscar usuário por ID público
# Objetivo: validar consulta individual.
# Esperado: 200; senha null.
# Requisitos: RF23.
GET {{baseUrl}}/api/usuarios/{{usuarioTesteIdPublico}}
Authorization: Bearer {{adminToken}}

### 04.06 — Buscar usuário inexistente
# Objetivo: validar tratamento de não encontrado.
# Esperado: 404.
# Requisitos: RF23, RF14.
GET {{baseUrl}}/api/usuarios/00000000-0000-0000-0000-000000000099
Authorization: Bearer {{adminToken}}

### 04.07 — Editar usuário
# Objetivo: atualizar nome, e-mail, perfil e unidade sem alterar senha.
# Esperado: 200; senha null.
# Requisitos: RF23.
PUT {{baseUrl}}/api/usuarios/{{usuarioTesteIdPublico}}
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "nome": "TESTE REST RECEPCAO EDITADO",
  "email": "teste.rest.recepcao@pet.com",
  "tipoUsuario": "RECEPCAO",
  "unidadeAtuacao": "CAPS_II",
  "senha": null
}

### 04.08 — Editar usuário como PROFISSIONAL
# Objetivo: confirmar bloqueio.
# Esperado: 403.
# Requisitos: RF23, RNF06.
PUT {{baseUrl}}/api/usuarios/{{usuarioTesteIdPublico}}
Authorization: Bearer {{profissionalToken}}
Content-Type: application/json

{
  "nome": "ALTERACAO INDEVIDA",
  "email": "teste.rest.recepcao@pet.com",
  "tipoUsuario": "ADMINISTRADOR",
  "unidadeAtuacao": "USF",
  "senha": null
}

### 04.09 — Excluir usuário de teste
# ATENÇÃO: esta requisição altera dados. Execute somente em ambiente de desenvolvimento.
# Objetivo: validar exclusão por ADMIN.
# Esperado: 204 No Content.
# Requisitos: RF23, RNF06.
DELETE {{baseUrl}}/api/usuarios/{{usuarioTesteIdPublico}}
Authorization: Bearer {{adminToken}}


# =================================================================================================
# 05 — UNIDADES DE SAÚDE
# =================================================================================================

### 05.01 — Listar unidades de saúde
# Objetivo: obter uma USF válida para o cadastro de pacientes.
# Esperado: 200. Para seguir, a lista precisa conter ao menos um objeto com id.
# Requisitos relacionados: RF22.
# @name listarUnidades
GET {{baseUrl}}/api/unidades-saude
Authorization: Bearer {{adminToken}}

> {%
client.test("Endpoint de unidades respondeu", function () {
  client.assert(response.status === 200, "Esperado HTTP 200.");
});
if (Array.isArray(response.body) && response.body.length > 0) {
  client.global.set("usfId", response.body[0].id);
} else {
  client.log("BLOQUEIO: nenhuma USF retornada. Não existe POST de unidade no backend.");
}
%}

### 05.02 — Listar unidades sem token
# Objetivo: confirmar proteção da rota.
# Esperado pela configuração atual: 403; registrar se 401.
# Requisitos: RNF05.
GET {{baseUrl}}/api/unidades-saude

# FALHA/GAP: não existe endpoint de criação, edição, consulta individual ou exclusão de USF.
# A suíte só consegue listar e reutilizar uma unidade previamente sincronizada/persistida.


# =================================================================================================
# 06 — PACIENTES
# =================================================================================================

### 06.01 — Criar paciente com endereço fixo
# Objetivo: cadastrar todos os campos efetivamente obrigatórios de PacienteDTO.
# Esperado: 201; statusPaciente deve ser ATIVO; copiar/capturar idPublico.
# Requisitos: RF22, RF14, RF15.
# @name criarPacienteFixo
POST {{baseUrl}}/api/pacientes?ignorarSimilaridade=false
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "idPublico": null,
  "nome": "PACIENTE TESTE API",
  "nomeMae": "MAE PACIENTE TESTE API",
  "dataNascimento": "1990-05-10",
  "dataUltimaPresenca": null,
  "sexo": "FEMININO",
  "racacor": "PARDA",
  "cns": "{{cnsPacienteFixo}}",
  "cpf": "{{cpfPacienteFixo}}",
  "telefone": "75999990001",
  "endereco": {
    "id": null,
    "cidade": "Santo Antônio de Jesus",
    "estado": "BA",
    "bairro": "Centro",
    "logradouro": "Rua Teste REST",
    "numero": "100",
    "complemento": "Próximo ao IFBA",
    "cep": "44570000"
  },
  "situacaoRua": false,
  "tipoAcompanhamento": "INDIVIDUAL",
  "countFaltas": null,
  "statusPaciente": null,
  "usfReferencia": {
    "id": {{usfId}}
  },
  "capsReferencia": "CAPS_AD"
}



### 06.02 — Criar paciente em situação de rua com ponto de referência
# Objetivo: validar cenário de rua usando Endereco como equipamento/ponto de apoio.
# Esperado: 201.
# Requisitos: RF22, RF08.
# @name criarPacienteRua
POST {{baseUrl}}/api/pacientes?ignorarSimilaridade=false
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "nome": "PACIENTE TESTE RUA",
  "nomeMae": "MAE PACIENTE TESTE RUA",
  "dataNascimento": "1985-08-20",
  "dataUltimaPresenca": null,
  "sexo": "MASCULINO",
  "racacor": "PRETA",
  "cns": "{{cnsPacienteRua}}",
  "cpf": "{{cpfPacienteRua}}",
  "telefone": "75999990002",
