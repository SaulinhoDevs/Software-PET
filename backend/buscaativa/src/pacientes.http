# =================================================================================================
# 07 — BUSCA ATIVA, FALTAS, RISCO E ENCERRAMENTO
# =================================================================================================

### 07.01 — Criar paciente dedicado aos testes de risco
# Objetivo: não destruir o paciente principal.
# Esperado: 201.
# Requisitos: RF09, RF10, RF02, RF08, RF16.
# @name criarPacienteRisco
POST {{baseUrl}}/api/pacientes
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "nome": "PACIENTE TESTE RISCO",
  "nomeMae": "MAE PACIENTE TESTE RISCO",
  "dataNascimento": "1980-03-15",
  "dataUltimaPresenca": null,
  "sexo": "MASCULINO",
  "racacor": "PARDA",
  "cns": "{{cnsPacienteRisco}}",
  "cpf": "{{cpfPacienteRisco}}",
  "telefone": "75999990007",
  "endereco": {
    "cidade": "Santo Antônio de Jesus",
    "estado": "BA",
    "bairro": "Centro",
    "logradouro": "Rua Busca Ativa",
    "numero": "3",
    "complemento": "Casa azul",
    "cep": "44570000"
  },
  "situacaoRua": false,
  "tipoAcompanhamento": "INDIVIDUAL",
  "usfReferencia": {"id": {{usfId}}},
  "capsReferencia": "CAPS_AD"
}



### 07.02 — Consultar busca ativa antes das faltas
# Objetivo: estabelecer baseline.
# Esperado: 200; paciente novo não deve aparecer.
# Requisitos: RF10, RF02.
GET {{baseUrl}}/api/pacientes/busca-ativa
Authorization: Bearer {{adminToken}}

### 07.03 — Consultar paciente após uma falta
# Execute antes: 09.05 e 09.06.
# Objetivo: verificar countFaltas = 1.
# Esperado: 200; paciente ainda não deve estar em busca ativa vermelha.
# Requisitos: RF09.
GET {{baseUrl}}/api/pacientes/{{pacienteRiscoIdPublico}}
Authorization: Bearer {{adminToken}}

### 07.04 — Consultar paciente após duas faltas
# Execute antes: 09.07 e 09.08.
# Objetivo: verificar countFaltas = 2.
# Regra interna: classificação AMARELO.
# GAP de contrato: PacienteDTO não expõe classificacaoRisco; a cor amarela não é confirmável via endpoint.
# Requisitos: RF09, RF10.
GET {{baseUrl}}/api/pacientes/{{pacienteRiscoIdPublico}}
Authorization: Bearer {{adminToken}}

### 07.05 — Consultar paciente e busca ativa após três faltas
# Execute antes: 09.09 e 09.10.
# Objetivo: verificar countFaltas = 3 e inclusão na busca ativa.
# Esperado: paciente ATIVO e VERMELHO aparece em /busca-ativa.
# Requisitos: RF09, RF10, RF02.
GET {{baseUrl}}/api/pacientes/{{pacienteRiscoIdPublico}}
Authorization: Bearer {{adminToken}}

###
GET {{baseUrl}}/api/pacientes/busca-ativa
Authorization: Bearer {{adminToken}}

> {%
const lista = Array.isArray(response.body) ? response.body : [];
const item = lista.find(p => p.idPublico === "{{pacienteRiscoIdPublico}}");
client.test("Paciente vermelho aparece na busca ativa", function () {
  client.assert(item, "Paciente de risco não apareceu.");
  client.assert(item.classificacaoRisco === "VERMELHO", "Risco deveria ser VERMELHO.");
  client.assert(item.faltasConsecutivas >= 3, "Faltas consecutivas abaixo de 3.");
});
if (item) {
  client.test("Campos disponíveis do RF02", function () {
    client.assert(item.nome, "nome ausente");
    client.assert(item.idPublico, "idPublico ausente");
    client.assert(item.faltasConsecutivas !== undefined, "faltasConsecutivas ausente");
  });
}
%}

# FALHA/GAP RF02: AlertaBuscaAtivaDTO NÃO retorna CNS, tipoAcompanhamento nem dataUltimaPresenca.
# Campos retornados: idPublico, nome, classificacaoRisco, faltasConsecutivas, alerta,
# localBusca e avisoAdicional.

### 07.06 — Registrar presença após faltas e consultar paciente
# Execute primeiro 09.11.
# Objetivo: confirmar countFaltas = 0 e dataUltimaPresenca atualizada.
# Comportamento real: dataUltimaPresenca recebe LocalDate.now(), não a data do agendamento.
# Requisitos: RF09, RF06.
GET {{baseUrl}}/api/pacientes/{{pacienteRiscoIdPublico}}
Authorization: Bearer {{adminToken}}

### 07.07 — Busca ativa após presença
# Objetivo: confirmar remoção do paciente após risco recalculado.
# Esperado: paciente não aparece se deixou de ser VERMELHO.
# Requisitos: RF09, RF10.
GET {{baseUrl}}/api/pacientes/busca-ativa
Authorization: Bearer {{adminToken}}

### 07.08 — Encerrar com ALTA_TERAPEUTICA como PROFISSIONAL
# ATENÇÃO: esta requisição altera dados. Execute somente em ambiente de desenvolvimento.
# Objetivo: validar RF16 e permissão PROFISSIONAL.
# Esperado: 204; paciente deixa de aparecer na busca ativa.
# Requisitos: RF16, RNF06.
PATCH {{baseUrl}}/api/pacientes/{{pacienteRiscoIdPublico}}/encerrar
Authorization: Bearer {{profissionalToken}}
Content-Type: application/json

{
  "motivo": "ALTA_TERAPEUTICA",
  "statusPaciente": "ALTA_TERAPEUTICA",
  "descricao": "Alta registrada pelo teste REST."
}

