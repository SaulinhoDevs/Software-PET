@baseUrl = http://localhost:8080/api
# Após fazer o login, cole o token gerado aqui (sem aspas):
@token = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJidXNjYWF0aXZhLWFwaSIsInN1YiI6ImFkbWluQHBldC5jb20iLCJleHAiOjE3ODM3MzU2MTJ9.XqBBGxJIOwYjFXFLik-Rbz_dNwYsMoawiyOoIsamDH4"

# Após criar um paciente, cole o ID (UUID) dele aqui para testar as buscas, edição e inativação:
@idPaciente = cole_o_uuid_aqui

### ==========================================
### 1. AUTENTICAÇÃO
### ==========================================

# Login com ADMINISTRADOR (Tem acesso a TUDO: POST, PUT, DELETE e GETs)
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "admin@pet.com",
  "senha": "123456"
}

###

# Login com PROFISSIONAL (Só tem acesso aos GETs. Se tentar POST/PUT/DELETE, vai tomar 403 Forbidden)
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "medico@pet.com",
  "senha": "123456"
}


### ==========================================
### 2. ENDPOINTS ABERTOS PARA QUALQUER ROLE
### ==========================================

### Listar todos os pacientes
GET {{baseUrl}}/pacientes
Authorization: Bearer {{token}}

###

### Buscar paciente por ID (UUID)
GET {{baseUrl}}/pacientes/{{idPaciente}}
Authorization: Bearer {{token}}

###

### Buscar paciente por CPF
GET {{baseUrl}}/pacientes/busca/cpf/12345678909
Authorization: Bearer {{token}}

###

### Buscar paciente por CNS
GET {{baseUrl}}/pacientes/busca/cns/123456789012345
Authorization: Bearer {{token}}

###

### Buscar paciente por Nome (usando o parâmetro 'q')
GET {{baseUrl}}/pacientes/busca/nome?q=Maria
Authorization: Bearer {{token}}


### ==========================================
### 3. ENDPOINTS RESTRITOS (ROLE: ADMINISTRADOR)
### ==========================================

### Cadastrar novo Paciente
# Atenção: O token deve ser obrigatoriamente do admin@pet.com
POST {{baseUrl}}/pacientes?ignorarSimilaridade=false
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "nome": "Maria Silva",
  "nomeMae": "Josefa Silva",
  "dataNascimento": "1990-05-15",
  "sexo": "FEMININO",
  "racacor": "PARDA",
  "cns": "123456789012345",
  "cpf": "12345678909",
  "telefone": "75988887777",
  "situacaoRua": false,
  "tipoAcompanhamento": "INDIVIDUAL",
  "countFaltas": 0,
  "statusPaciente": "ATIVO"
}

###

### Atualizar Paciente Existente
PUT {{baseUrl}}/pacientes/{{idPaciente}}?ignorarSimilaridade=false
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "nome": "Maria Silva Atualizada",
  "nomeMae": "Josefa Silva",
  "dataNascimento": "1990-05-15",
  "sexo": "FEMININO",
  "racacor": "PARDA",
  "cns": "123456789012345",
  "cpf": "12345678909",
  "telefone": "75988887777",
  "situacaoRua": false,
  "tipoAcompanhamento": "INDIVIDUAL",
  "countFaltas": 0,
  "statusPaciente": "ATIVO"
}

###

### Inativar Paciente
DELETE {{baseUrl}}/pacientes/{{idPaciente}}
Authorization: Bearer {{token}}