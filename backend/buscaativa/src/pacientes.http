PATCH {{baseUrl}}/api/pacientes/{{pacienteRiscoIdPublico}}/reativar
Authorization: Bearer {{profissionalToken}}
Content-Type: application/json

{
  "motivo": "Retorno ao tratamento."
}

### 07.16 — Reativar como RECEPCAO
# Objetivo: confirmar restrição exclusiva a ADMIN.
# Esperado: 403.
# Requisitos: RF16, RNF06.
PATCH {{baseUrl}}/api/pacientes/{{pacienteRiscoIdPublico}}/reativar
Authorization: Bearer {{recepcaoToken}}
Content-Type: application/json

{
  "motivo": "Retorno ao tratamento."
}

### 07.17 — Reativar como ADMIN
# ATENÇÃO: esta requisição altera dados. Execute somente em ambiente de desenvolvimento.
# Objetivo: validar reativação.
# Esperado: 204; status volta a ATIVO.
# Requisitos: RF16.
PATCH {{baseUrl}}/api/pacientes/{{pacienteRiscoIdPublico}}/reativar
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "motivo": "Paciente retomou acompanhamento."
}

### 07.18 — Inativar paciente vermelho/ativo como ADMIN
# ATENÇÃO: esta requisição altera dados. Execute somente em ambiente de desenvolvimento.
# Objetivo: confirmar que INATIVO deixa de aparecer na busca ativa.
# Esperado: 204.
# Requisitos: RF22, RF10.
DELETE {{baseUrl}}/api/pacientes/{{pacienteRiscoIdPublico}}
Authorization: Bearer {{adminToken}}

### 07.19 — Consultar busca ativa após inativação/encerramento
# Objetivo: confirmar filtro StatusPaciente.ATIVO + ClassificacaoRisco.VERMELHO.
# Esperado: paciente inativo/encerrado não aparece.
# Requisitos: RF10, RF16.
GET {{baseUrl}}/api/pacientes/busca-ativa
Authorization: Bearer {{adminToken}}

# RF13
# FALHA/GAP RF13: os critérios estão fixos em PacienteServiceImpl e não há endpoint de configuração
# por unidade/perfil ADMIN:
# - GRUPO_TERAPEUTICO: amarelo >15 dias; vermelho >30 dias;
# - INDIVIDUAL e AMBOS: amarelo >60 dias; vermelho >120 dias;
# - faltas amarelo >=2; vermelho >=3.
# POSSÍVEL GAP: AMBOS cai no mesmo ramo de INDIVIDUAL.
#
# Auditoria de encerramento/reativação
# Entidades possuem campos e Envers, mas não existe endpoint de auditoria para conferir data,
# usuário, motivo de reativação ou quem visualizou/encaminhou uma busca ativa.
# Classificação: NÃO VERIFICÁVEL VIA REST CLIENT sem endpoint.


# =================================================================================================
# 08 — DISPONIBILIDADE E BLOQUEIOS
