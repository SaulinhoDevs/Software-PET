}

### 07.11 — Motivo OUTRO com descrição
# ATENÇÃO: esta requisição altera dados. Execute somente em ambiente de desenvolvimento.
# Objetivo: validar encerramento com descrição.
# Esperado: 204.
# Requisitos: RF16.
PATCH {{baseUrl}}/api/pacientes/{{pacienteRuaIdPublico}}/encerrar
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "motivo": "OUTRO",
  "statusPaciente": "OUTRO",
  "descricao": "Mudança de município informada pela equipe."
}

### 07.12 — Encerrar com mesmo status
# Objetivo: validar regra contra repetição.
# Esperado: 400.
# Requisitos: RF16.
PATCH {{baseUrl}}/api/pacientes/{{pacienteRuaIdPublico}}/encerrar
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "motivo": "OUTRO",
  "statusPaciente": "OUTRO",
  "descricao": "Repetição."
}

### 07.13 — Tentar usar status ATIVO no encerramento
# Objetivo: testar mensagem/regra "não deve ter status ATIVO".
# POSSÍVEL BUG: o código só rejeita quando o status novo é igual ao atual; não rejeita ATIVO explicitamente.
# Em paciente encerrado, esta chamada pode retornar 204 e reativar indevidamente fora do endpoint /reativar.
# Requisitos: RF16, RNF09.
PATCH {{baseUrl}}/api/pacientes/{{pacienteRuaIdPublico}}/encerrar
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "motivo": "OUTRO",
  "statusPaciente": "ATIVO",
  "descricao": "TESTE DE BUG — status ATIVO em encerrar."
}

### 07.14 — Reativar sem motivo
# Objetivo: validar @NotBlank.
# Esperado: 422.
# Requisitos: RF16.
PATCH {{baseUrl}}/api/pacientes/{{pacienteRiscoIdPublico}}/reativar
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "motivo": ""
}

