### 08.01 — Criar disponibilidade para o profissional alvo como ADMIN
# Objetivo: cadastrar disponibilidade semanal MANHA.
# Ajuste @diaSemanaAgenda para o dia da semana de @amanha.
# Esperado: 200 OK (controller não retorna 201).
# Requisitos: RF04.
# @name criarDisponibilidade
POST {{baseUrl}}/api/disponibilidade-config/disponibilidade
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "id": null,
  "usuarioId": "{{profissionalIdPublico}}",
  "diaSemana": "{{diaSemanaAgenda}}",
  "turno": "MANHA",
  "capacidade": 2
}


### 08.02 — Criar disponibilidade TARDE como o próprio PROFISSIONAL
# Objetivo: confirmar que profissional cadastra a própria disponibilidade.
# O usuarioId enviado é ignorado para não-admin; o usuário alvo será o logado.
# Esperado: 200.
# Requisitos: RF04, RNF06.
POST {{baseUrl}}/api/disponibilidade-config/disponibilidade
Authorization: Bearer {{profissionalToken}}
Content-Type: application/json

{
  "id": null,
  "usuarioId": "{{profissional2IdPublico}}",
  "diaSemana": "{{diaSemanaAgenda}}",
  "turno": "TARDE",
  "capacidade": 2
}

### 08.03 — Duplicidade profissional + dia + turno
# Objetivo: validar unicidade.
# Esperado: 409.
# Requisitos: RF04, RNF09.
POST {{baseUrl}}/api/disponibilidade-config/disponibilidade
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "id": null,
  "usuarioId": "{{profissionalIdPublico}}",
  "diaSemana": "{{diaSemanaAgenda}}",
  "turno": "MANHA",
  "capacidade": 5
}

### 08.04 — Atualizar disponibilidade pelo mesmo POST informando id
# Objetivo: testar implementação de edição sem PUT.
# Esperado: 200 e capacidade 3.
# Requisitos: RF04.
POST {{baseUrl}}/api/disponibilidade-config/disponibilidade
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "id": {{disponibilidadeId}},
  "usuarioId": "{{profissionalIdPublico}}",
  "diaSemana": "{{diaSemanaAgenda}}",
  "turno": "MANHA",
  "capacidade": 3
}

### 08.05 — Capacidade negativa
# Objetivo: verificar validação de domínio.
# Comportamento real provável: 200, pois DTO só possui @NotNull e não @Positive.
# POSSÍVEL BUG RF04 se capacidade deve ser positiva.
POST {{baseUrl}}/api/disponibilidade-config/disponibilidade
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "id": null,
  "usuarioId": "{{profissionalIdPublico}}",
  "diaSemana": "SUNDAY",
  "turno": "MANHA",
  "capacidade": -1
}

### 08.06 — Listar disponibilidade como ADMIN escolhendo profissional
# Objetivo: listar recursos de um profissional alvo.
# Esperado: 200.
# Requisitos: RF04.
GET {{baseUrl}}/api/disponibilidade-config/disponibilidade?usuarioId={{profissionalIdPublico}}
Authorization: Bearer {{adminToken}}

### 08.07 — Listar como PROFISSIONAL tentando escolher outro
# Objetivo: confirmar isolamento de leitura.
# Comportamento esperado pelo service: 200, mas retorna apenas os recursos do usuário logado.
# Requisitos: RF04, RNF06.
GET {{baseUrl}}/api/disponibilidade-config/disponibilidade?usuarioId={{profissional2IdPublico}}
Authorization: Bearer {{profissionalToken}}

### 08.08 — Listar como RECEPCAO
# Objetivo: validar permissão de leitura.
# Esperado: 200; sem usuarioId, UsuarioContextService retorna a própria recepção.
# Isso tende a retornar [] e não permite à recepção escolher profissional alvo, pois só ADMIN usa usuarioId.
# POSSÍVEL GAP funcional na consulta de agenda.
GET {{baseUrl}}/api/disponibilidade-config/disponibilidade?usuarioId={{profissionalIdPublico}}
Authorization: Bearer {{recepcaoToken}}

### 08.09 — Criar disponibilidade para profissional 2
# Objetivo: preparar teste de exclusão indevida por outro profissional.
# Esperado: 200.
# @name criarDisponibilidadeProf2
POST {{baseUrl}}/api/disponibilidade-config/disponibilidade
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "id": null,
  "usuarioId": "{{profissional2IdPublico}}",
  "diaSemana": "{{diaSemanaAgenda}}",
  "turno": "MANHA",
  "capacidade": 2
}


### 08.10 — PROFISSIONAL tenta excluir disponibilidade de outro profissional
# ATENÇÃO: esta requisição altera dados. Execute somente em ambiente de desenvolvimento.
# Objetivo: verificar autorização por propriedade.
# Resultado provável: 204, pois deletarDisponibilidade(id) não valida dono.
# FALHA RNF06 se a exclusão ocorrer.
DELETE {{baseUrl}}/api/disponibilidade-config/disponibilidade/{{disponibilidadeProf2Id}}
Authorization: Bearer {{profissionalToken}}

### 08.11 — RECEPCAO tenta excluir disponibilidade
# Objetivo: confirmar bloqueio por perfil.
# Esperado: 403.
DELETE {{baseUrl}}/api/disponibilidade-config/disponibilidade/{{disponibilidadeId}}
Authorization: Bearer {{recepcaoToken}}

### 08.12 — Criar bloqueio de agenda
# Objetivo: bloquear a data de amanhã.
# Esperado: 200.
# Requisitos: RF04.
# @name criarBloqueio
POST {{baseUrl}}/api/bloqueioAgenda-config
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "id": null,
  "usuarioId": "{{profissionalIdPublico}}",
  "dataInicio": "2026-07-23",
  "dataFim": "2026-07-23",
  "motivoBloqueio": "TESTE REST — reunião de equipe"
}


### 08.13 — Listar bloqueios
# Objetivo: confirmar persistência.
# Esperado: 200.
# Requisitos: RF04.
GET {{baseUrl}}/api/bloqueioAgenda-config?usuarioId={{profissionalIdPublico}}
Authorization: Bearer {{adminToken}}

### 08.14 — Consultar vagas em data bloqueada
# Objetivo: validar retorno zero em MANHA e TARDE.
# Esperado: 200; {"MANHA":0,"TARDE":0}.
# Requisitos: RF04.
GET {{baseUrl}}/api/agendamentos/vagas?usuarioId={{profissionalIdPublico}}&data={{amanha}}
Authorization: Bearer {{adminToken}}

### 08.15 — Excluir bloqueio
# ATENÇÃO: esta requisição altera dados. Execute somente em ambiente de desenvolvimento.
# Objetivo: reabrir a data.
# Esperado: 204.
# Requisitos: RF04.
DELETE {{baseUrl}}/api/bloqueioAgenda-config/{{bloqueioId}}
Authorization: Bearer {{adminToken}}

### 08.16 — Consultar vagas após remover bloqueio
# Objetivo: conferir capacidade configurada menos ocupação.
# Esperado: 200; MANHA deve refletir capacidade se @diaSemanaAgenda corresponder a @amanha.
# Requisitos: RF04.
GET {{baseUrl}}/api/agendamentos/vagas?usuarioId={{profissionalIdPublico}}&data={{amanha}}
Authorization: Bearer {{adminToken}}

### 08.17 — Excluir disponibilidade principal
# ATENÇÃO: esta requisição altera dados. Execute somente em ambiente de desenvolvimento.
# Execute apenas depois de concluir os testes de vagas/agendamento.
# Esperado: 204.
DELETE {{baseUrl}}/api/disponibilidade-config/disponibilidade/{{disponibilidadeId}}
Authorization: Bearer {{adminToken}}


